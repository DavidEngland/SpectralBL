  journal = {Atmospheric Science Letters},
  keywords = {heavy rainfall, strong winds, lee waves, orography, Southern Alps},
  number = {3},
  pages = {119--128},
  title = {A high-resolution modelling case study of a severe weather event over New Zealand},
