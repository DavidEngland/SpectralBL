@article{Dyer1974,
  abstract = {Flux-profile relationships in the constant flux layer are reviewed. The preferred relationships are found to be those of Dyer and Hicks (1970), namely, $\phi$H=$\phi$W=(1−16(z/L))−1/2, $\phi$M=(1−16(z/L))−1/4 for the unstable region, and $\phi$H=$\phi$W=$\phi$M= 1+5(z/L) for the stable region.},
